generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String
}

model Discipline {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  labs  LabWork[]
}

model LabWork {
  id           Int        @id @default(autoincrement())
  title        String
  description  String?
  deadline     DateTime
  status       String     @default("До виконання")

  disciplineId Int
  discipline   Discipline @relation(fields: [disciplineId], references: [id])
}
